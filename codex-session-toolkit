#!/usr/bin/env sh
set -eu

# Force UTF-8 so Chinese filenames/paths/TUI output stay intact under POSIX
# locales like C/POSIX where Python would otherwise default to ASCII stdio.
# (No-op on systems whose locale is already UTF-8 — env vars are honoured.)
: "${PYTHONUTF8:=1}"
: "${PYTHONIOENCODING:=utf-8}"
export PYTHONUTF8 PYTHONIOENCODING

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
# After PR 3 the codex CLI lives under ai_cli_kit.codex; the package directory
# probe + ``python -m`` target both reflect that. The console script name and
# user-facing command stay ``codex-session-toolkit`` for backwards compatibility.
PACKAGE_DIR_NAME="ai_cli_kit"
PACKAGE_MODULE="ai_cli_kit.codex"
VENV_DIR="${VENV_DIR:-$SCRIPT_DIR/.venv}"
VENV_COMMAND="$VENV_DIR/bin/codex-session-toolkit"
SRC_DIR="$SCRIPT_DIR/src"
PACKAGE_DIR="$SRC_DIR/$PACKAGE_DIR_NAME/codex"
LAUNCH_MODE="${CST_LAUNCH_MODE:-${CSC_LAUNCH_MODE:-auto}}"
IS_GIT_WORKTREE=0

if [ -d "$SCRIPT_DIR/.git" ] && [ -d "$PACKAGE_DIR" ]; then
  IS_GIT_WORKTREE=1
fi

run_venv() {
  echo "============================================="
  echo " Codex Session Toolkit - Launcher (Local Venv)"
  echo "============================================="
  echo ">> $VENV_COMMAND $*"
  exec "$VENV_COMMAND" "$@"
}

if [ ! -d "$PACKAGE_DIR" ] && [ "$LAUNCH_MODE" = "source" ]; then
  echo "Error: cannot find package source at $PACKAGE_DIR" >&2
  echo "Tip: run ./install.sh first, or keep the src/ tree intact." >&2
  exit 1
fi

if [ "$LAUNCH_MODE" = "installed" ] && [ -x "$VENV_COMMAND" ]; then
  run_venv "$@"
fi

if [ "$LAUNCH_MODE" = "auto" ] && [ "$IS_GIT_WORKTREE" -eq 0 ] && [ -x "$VENV_COMMAND" ]; then
  run_venv "$@"
fi

if [ ! -d "$PACKAGE_DIR" ]; then
  if [ -x "$VENV_COMMAND" ]; then
    run_venv "$@"
  fi
  echo "Error: cannot find package source at $PACKAGE_DIR" >&2
  echo "Tip: run ./install.sh first, or keep the src/ tree intact." >&2
  exit 1
fi

cd "$SCRIPT_DIR"

PYTHON_BIN="${PYTHON_BIN:-}"
if [ -z "$PYTHON_BIN" ]; then
  if command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
  elif command -v python >/dev/null 2>&1; then
    PYTHON_BIN="python"
  else
    echo "Error: python3/python not found in PATH." >&2
    echo "Tip: install Python 3 first, then rerun ./install.sh." >&2
    exit 127
  fi
fi

echo "============================================="
echo " Codex Session Toolkit - Launcher (Source Mode)"
echo "============================================="
echo ">> $PYTHON_BIN -m $PACKAGE_MODULE $*"

python_os_name() {
  "$PYTHON_BIN" -c 'import os; print(os.name)' 2>/dev/null || printf '%s\n' "posix"
}

python_pathsep() {
  "$PYTHON_BIN" -c 'import os; print(os.pathsep)' 2>/dev/null || printf '%s\n' ":"
}

python_import_path() {
  path="$1"
  py_os="$2"
  if [ "$py_os" = "nt" ] && command -v cygpath >/dev/null 2>&1; then
    cygpath -w "$path"
  else
    printf '%s\n' "$path"
  fi
}

PYTHON_OS_NAME="$(python_os_name)"
PYTHON_PATHSEP="$(python_pathsep)"
PYTHON_SRC_DIR="$(python_import_path "$SRC_DIR" "$PYTHON_OS_NAME")"
export PYTHONPATH="$PYTHON_SRC_DIR${PYTHONPATH:+$PYTHON_PATHSEP$PYTHONPATH}"
exec "$PYTHON_BIN" -m "$PACKAGE_MODULE" "$@"
